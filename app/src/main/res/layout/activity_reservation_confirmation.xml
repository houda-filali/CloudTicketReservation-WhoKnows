<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_pink_gradient"
    android:padding="18dp">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:textAllCaps="false"
        android:textColor="#6B2B2B"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/card_soft"
        android:padding="22dp"
        android:orientation="vertical"
        app:layout_constraintWidth_max="420dp"
        app:layout_constrainedWidth="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvConfirmTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reservation confirmed"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#6B2B2B"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvConfirmDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Details here"
            android:textColor="#7A3A3A"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/btn_pill"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="Back"
            android:textAllCaps="false"
            android:textColor="#6B2B2B"
            app:cornerRadius="26dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoMyReservations"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/btn_pill"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="My Reservations"
            android:textAllCaps="false"
            android:textColor="#6B2B2B"
            app:cornerRadius="26dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoEvents"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/btn_pill"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="Back to Events"
            android:textAllCaps="false"
            android:textColor="#6B2B2B"
            app:cornerRadius="26dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>