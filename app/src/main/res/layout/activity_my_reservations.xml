<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_pink_gradient"
    android:padding="18dp">

    <TextView
        android:id="@+id/tvResHeaderTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="My Reservations"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#6B2B2B"
        android:gravity="center"
        android:layout_marginTop="6dp"
        android:layout_marginStart="84dp"
        android:layout_marginEnd="84dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="Logout"
        android:textAllCaps="false"
        android:textColor="#6B2B2B"
        android:background="@drawable/btn_pill"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        app:cornerRadius="20dp"
        app:layout_constraintTop_toTopOf="@id/tvResHeaderTitle"
        app:layout_constraintBottom_toBottomOf="@id/tvResHeaderTitle"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvEmptyReservations"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="No reservations found"
        android:textColor="#7A3A3A"
        android:gravity="center"
        android:visibility="gone"
        android:padding="16dp"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/tvResHeaderTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMyReservations"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/tvResHeaderTitle"
        app:layout_constraintBottom_toTopOf="@id/btnBackFromReservations"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackFromReservations"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="Back"
        android:textAllCaps="false"
        android:textColor="#6B2B2B"
        android:background="@drawable/btn_pill"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        app:cornerRadius="26dp"
        android:layout_marginTop="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>