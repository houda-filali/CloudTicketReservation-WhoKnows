<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_pink_gradient"
    android:padding="18dp">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogoutGhost"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="Logout"
        android:textAllCaps="false"
        android:visibility="invisible"
        android:background="@drawable/btn_pill"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        app:cornerRadius="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvAdminDashboardTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Admin Dashboard"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#6B2B2B"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="@id/btnLogoutGhost"
        app:layout_constraintBottom_toBottomOf="@id/btnLogoutGhost"
        app:layout_constraintStart_toEndOf="@id/btnLogoutGhost"
        app:layout_constraintEnd_toStartOf="@id/btnLogout"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="Logout"
        android:textAllCaps="false"
        android:textColor="#6B2B2B"
        android:background="@drawable/btn_pill"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        app:cornerRadius="20dp"
        app:layout_constraintTop_toTopOf="@id/btnLogoutGhost"
        app:layout_constraintBottom_toBottomOf="@id/btnLogoutGhost"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddEvent"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="Add Event"
        android:textAllCaps="false"
        android:textColor="#6B2B2B"
        android:background="@drawable/btn_pill"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        app:cornerRadius="26dp"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/btnLogout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvAdminEmpty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="No events found"
        android:textColor="#7A3A3A"
        android:gravity="center"
        android:visibility="gone"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnAddEvent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAdminEvents"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/btnAddEvent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>